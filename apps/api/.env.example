# Copy to .env for local dev. Everything here has a working local default in
# app/config.py; you only need to set the GitHub/AI/email vars when you wire
# those integrations up (Phases 3-4).

ENV=local
DEBUG=true

APP_URL=http://localhost:3000
API_URL=http://localhost:8000
ROOT_DOMAIN=shiplog.app

DATABASE_URL=postgresql+asyncpg://shiplog:shiplog@localhost:5432/shiplog
REDIS_URL=redis://localhost:6379/0

# Change these in any real environment.
JWT_SECRET=dev-insecure-change-me
ENCRYPTION_KEY=dev-insecure-32byte-master-key!!

# GitHub OAuth (login) — Phase 1
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App (ingestion) — Phase 3
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Email — Phase 4 (console just logs locally)
EMAIL_BACKEND=console
EMAIL_FROM=Shiplog <updates@shiplog.app>
RESEND_API_KEY=

# Queue — local runs jobs in-process; sqs uses the URLs below
QUEUE_BACKEND=local
SQS_WEBHOOK_URL=
SQS_EMAIL_URL=
SQS_AI_URL=
